# Godot-specific ignores
.godot/
.import/
export_presets.cfg

# Imported binary assets (if you aren't using the .import folder)
# Packed textures/sounds are re-generated by Godot anyway
*.translation

# Mono/C# specific ignores (if using the .NET version)
.mono/
data_*/
mono_crash_*.json
*.csproj
*.sln
*.suo
*.pdb
*.obj
bin/
obj/

# Crash dumps and logs
*.log
godot.log

# OS-specific overrides
.DS_Store
Thumbs.db

# Build exports (Optional: protects your export folder)
# Create a folder named 'builds' or 'exports' if you use this
builds/
exports/
